{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "outDir": "../dist-electron",
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["*.ts", "../shared/parseManusJSON.ts", "../shared/parseLineFormat.ts", "../shared/normalizeCardData.ts", "../shared/queryClassifier.ts"]
}
